# Postgres (matches docker-compose.yml defaults)
MIDAS_DATABASE_URL=postgresql+asyncpg://midas:midas@localhost:5432/midas

# SEC EDGAR requires an identifying User-Agent. Format: "name contact-email"
MIDAS_SEC_USER_AGENT=midas-research your-email@example.com

# Anthropic API key for the Claude extractor
MIDAS_ANTHROPIC_API_KEY=

# Where raw fetched documents are cached on disk
MIDAS_CACHE_DIR=data/raw

# Global request rate limit (requests/sec, applies to shared HTTP client)
MIDAS_HTTP_RATE_LIMIT_PER_SEC=8
